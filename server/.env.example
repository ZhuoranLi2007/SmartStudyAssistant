SMARTSTUDY_ENVIRONMENT=development
SMARTSTUDY_DATABASE_URL=sqlite+aiosqlite:///./server/smartstudy.db
SMARTSTUDY_JWT_SECRET=replace-with-a-long-random-secret
SMARTSTUDY_ACCESS_TOKEN_MINUTES=1440
SMARTSTUDY_AI_PROVIDER=mock
SMARTSTUDY_AI_BASE_URL=https://api.deepseek.com
SMARTSTUDY_AI_API_KEY=
SMARTSTUDY_AI_MODEL=deepseek-chat
SMARTSTUDY_MAX_CHAT_MESSAGES=20

